# Supabase (public — safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-me

# Browser -> Next.js (same-origin API route/rewrite)
NEXT_PUBLIC_API_URL=/api

# Next.js server -> backend (server-side only; never exposed to the browser)
NEXT_SERVER_API_URL=http://127.0.0.1:8000

# NOTE: the Supabase secret/service-role key MUST NEVER appear in this file —
# it belongs only in backend/.env as SUPABASE_SECRET_KEY.
